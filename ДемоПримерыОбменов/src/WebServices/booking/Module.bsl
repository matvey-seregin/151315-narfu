// Функция проверяет, что строка является UUID через регулярное выражение
// Параметры:
//   Строка - Строка - строка, которую необходимо проверить
// Возвращаемое значение:
//   Булево - Истина, если строка является UUID
Функция ЭтоУникальныйИдентификатор(Строка)
	
	РегулярноеВыражение = "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$";
	Возврат СтрПодобнаПоРегулярномуВыражению(Строка, РегулярноеВыражение);
	
КонецФункции

// Применяет фильтры к тексту запроса на основе переданных параметров
//
// Параметры:
//   Запрос - Запрос - исходный запрос для применения фильтров
//   Фильтры - см. ПрочитатьФильтры
Процедура ПрименитьФильтры(Запрос, Фильтры)
	
	Схема = Новый СхемаЗапроса();
	Схема.УстановитьТекстЗапроса(Запрос.Текст);
	
	ЗапросПакета = Схема.ПакетЗапросов[0];
	Оператор = ЗапросПакета.Операторы[0];
	
	Если Фильтры.Номер <> Неопределено Тогда
		Оператор.Отбор.Добавить("ДатыБронирований.Номер В (&Номера)");
		Запрос.УстановитьПараметр("Номера", Фильтры.Номер);
	КонецЕсли;
	
	Если Фильтры.ДатаНачала <> Неопределено Тогда
		Оператор.Отбор.Добавить("ДатыБронирований.ДатаОкончания > &ДатаНачала");
		Запрос.УстановитьПараметр("ДатаНачала", Фильтры.ДатаНачала);
	КонецЕсли;
	
	Если Фильтры.ДатаОкончания <> Неопределено Тогда
		Оператор.Отбор.Добавить("ДатыБронирований.ДатаНачала < &ДатаОкончания");
		Запрос.УстановитьПараметр("ДатаОкончания", Фильтры.ДатаОкончания);
	КонецЕсли;
		
	Запрос.Текст = Схема.ПолучитьТекстЗапроса();
	
КонецПроцедуры

Функция ПрочитатьДанныеНовогоБронирования(Booking)
	
	Результат = Новый Структура;
	Результат.Вставить("Номер", ПолучитьНомер(Booking.roomId));
	Результат.Вставить("ДатаНачала", Booking.startDate);
	Результат.Вставить("ДатаОкончания", Booking.endDate);
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьНомер(ИдентификаторНомера)
	
	Если Не ЗначениеЗаполнено(ИдентификаторНомера) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Не ЭтоУникальныйИдентификатор(ИдентификаторНомера) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Ссылка = Справочники.Номера.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторНомера));
	
	Если Не НомерСуществует(Ссылка) Тогда
		Возврат Неопределено;
	КонецЕсли;
			
	Возврат Ссылка;
	
КонецФункции

// Проверяет существование номера в справочнике по заданной ссылке.
//
// Параметры:
//   Ссылка - СправочникСсылка.Номера - Ссылка на проверяемый элемент справочника
//
// Возвращаемое значение:
//   Булево - Истина, если номер существует; Ложь в противном случае
Функция НомерСуществует(Ссылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Номера.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номера КАК Номера
		|ГДЕ
		|	Номера.Ссылка = &Ссылка";
		
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Не Запрос.Выполнить().Пустой();

КонецФункции