
Функция CreateBooking(Booking)

	ДанныеНовогоБронирования = ПрочитатьДанныеНовогоБронирования(Booking);	
	
	Запись = РегистрыСведений.ДатыБронирований.СоздатьМенеджерЗаписи();
	Запись.Номер = ДанныеНовогоБронирования.Номер;
	Запись.ДатаНачала = ДанныеНовогоБронирования.ДатаНачала;
	Запись.ДатаОкончания = ДанныеНовогоБронирования.ДатаОкончания;
	
	Запись.Записать();
	
	Возврат Booking;
	
КонецФункции

Функция GetBookings(Filter)
	
	Фильтры = ПрочитатьФильтры(Filter);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ДатыБронирований.Номер КАК Номер,
		|	ДатыБронирований.ДатаНачала КАК ДатаНачала,
		|	ДатыБронирований.ДатаОкончания КАК ДатаОкончания
		|ИЗ
		|	РегистрСведений.ДатыБронирований КАК ДатыБронирований";
		
	ПрименитьФильтры(Запрос, Фильтры);
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	ТипСписокБронирований = ФабрикаXDTO.Тип("http://narfu.ru/151315/booking", "books");
	СписокБронированийXDTO = ФабрикаXDTO.Создать(ТипСписокБронирований);
		
	Пока Выборка.Следующий() Цикл
		
		ТипОписаниеБронирования = ФабрикаXDTO.Тип("http://narfu.ru/151315/booking", "book");
		ОписаниеБронированияXDTO = ФабрикаXDTO.Создать(ТипОписаниеБронирования);
		
		ОписаниеБронированияXDTO.roomId = Строка(Выборка.Номер.УникальныйИдентификатор());
		ОписаниеБронированияXDTO.startDate = Выборка.ДатаНачала;
		ОписаниеБронированияXDTO.endDate = Выборка.ДатаОкончания;
		
		СписокБронированийXDTO.book.Добавить(ОписаниеБронированияXDTO)
		
	КонецЦикла;
	
	Возврат СписокБронированийXDTO;	

КонецФункции

Функция ПрочитатьФильтры(Filter)
			
	Результат = Новый Структура;
	Результат.Вставить("Номер");
	Результат.Вставить("ДатаНачала");
	Результат.Вставить("ДатаОкончания");
	
	Если Filter = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Filter.rooms) Тогда
		Номера = Новый Массив;
		Для Каждого Идентификатор Из Filter.rooms Цикл
			Если ЭтоУникальныйИдентификатор(Идентификатор) Тогда
				Номера.Добавить(Справочники.Номера.ПолучитьСсылку(Новый УникальныйИдентификатор(Идентификатор)));
			КонецЕсли;
		КонецЦикла;
		Результат.Номер = Номера;
	КонецЕсли;
	
	Результат.ДатаНачала = Filter.startDate;
	Результат.ДатаОкончания = Filter.endDate;

	Возврат Результат;
	
КонецФункции

Функция GetRooms()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Номера.Код КАК Код,
		|	Номера.Наименование КАК Наименование,
		|	Номера.Ссылка КАК Ссылка,
		|	Номера.Описание КАК Описание
		|ИЗ
		|	Справочник.Номера КАК Номера";
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	ТипСписокНомеров = ФабрикаXDTO.Тип("http://narfu.ru/151315/booking", "rooms");
	СписокНомеровXDTO = ФабрикаXDTO.Создать(ТипСписокНомеров);
		
	Пока Выборка.Следующий() Цикл
		
		ТипОписаниеНомера = ФабрикаXDTO.Тип("http://narfu.ru/151315/booking", "room");
		ОписаниеНомераXDTO = ФабрикаXDTO.Создать(ТипОписаниеНомера);
		
		ОписаниеНомераXDTO.id = Строка(Выборка.Ссылка.УникальныйИдентификатор());
		ОписаниеНомераXDTO.code = Выборка.Код;
		ОписаниеНомераXDTO.name = Выборка.Наименование;
		ОписаниеНомераXDTO.description = Выборка.Описание;
		
		СписокНомеровXDTO.room.Добавить(ОписаниеНомераXDTO)
		
	КонецЦикла;
	
	Возврат СписокНомеровXDTO;

КонецФункции

