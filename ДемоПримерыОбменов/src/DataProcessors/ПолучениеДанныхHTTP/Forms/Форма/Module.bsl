
&НаКлиенте
Процедура ДобавитьБронирование(Команда)
	
	Если КешНомеров = Неопределено Тогда
		ОбновитьКешНомеров();
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("КешНомеров", КешНомеров);
	
	Оповещение = Новый ОписаниеОповещения("ДобавитьБронированиеЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("Обработка.ПолучениеДанныхHTTP.Форма.ВводНовогоБронирования", 
		ПараметрыФормы,,,,,
		Оповещение)

КонецПроцедуры

&НаКлиенте
Процедура ДобавитьБронированиеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДобавитьБронированиеСервер(Результат);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьБронированиеСервер(Результат)
	
	НастройкиПодключения = НастройкиПодключения();
	
	Соединение = УстановитьСоединение(НастройкиПодключения);
	
	АдресРесурса = НастройкиПодключения.ПутьНаСервере + "/hs/booking/bookings";
	
	ДанныеЗапроса = Новый Структура;
	ДанныеЗапроса.Вставить("room_id", Результат.Номер);
	ДанныеЗапроса.Вставить("start_date", ЗаписатьДатуJSON(Результат.ДатаНачала, ФорматДатыJSON.ISO));	
	ДанныеЗапроса.Вставить("end_date", ЗаписатьДатуJSON(Результат.ДатаОкончания, ФорматДатыJSON.ISO));
	
	ТелоЗапроса = ЗаписатьЗначениеJSON(ДанныеЗапроса);
	
	Запрос = Новый HTTPЗапрос(АдресРесурса);
	Запрос.УстановитьТелоИзСтроки(ТелоЗапроса);
	Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	
	Ответ = Соединение.ОтправитьДляОбработки(Запрос);
	
	Если Ответ.КодСостояния <> 200 Тогда
		Сообщить("Ошибка подключения: " + Ответ.КодСостояния);
		Возврат;
	КонецЕсли;
	
	ОбновитьНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьНаСервере()
	
	НастройкиПодключения = НастройкиПодключения();
	
	Соединение = УстановитьСоединение(НастройкиПодключения);
	
	АдресРесурса = НастройкиПодключения.ПутьНаСервере + "/hs/booking/bookings";
	
	Запрос = Новый HTTPЗапрос(АдресРесурса);
	Ответ = Соединение.Получить(Запрос);
	
	Если Ответ.КодСостояния <> 200 Тогда
		Сообщить("Ошибка подключения: " + Ответ.КодСостояния);
		Возврат;
	КонецЕсли;
	
	Бронирования.Очистить();
	
	ТелоОтвета = Ответ.ПолучитьТелоКакСтроку();
	
	ДанныеОтвета = ПрочитатьЗначениеJSON(ТелоОтвета);
	
	Для Каждого ДанныеБронирования Из ДанныеОтвета Цикл
		
		Строка = Бронирования.Добавить();
		Строка.ИдентификаторНомера = ДанныеБронирования.room_id;
		Строка.ДатаНачала = ПрочитатьДатуJSON(ДанныеБронирования.start_date, ФорматДатыJSON.ISO);
		Строка.ДатаОкончания = ПрочитатьДатуJSON(ДанныеБронирования.end_date, ФорматДатыJSON.ISO);
		
		ЗаполнитьСвойстваНомера(Строка);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваНомера(Строка)
	
	КешОбновлен = Ложь;
	
	Если КешНомеров = Неопределено Тогда
		ОбновитьКешНомеров();
		КешОбновлен = Истина;
	КонецЕсли;
	
	ДанныеНомера = ПолучитьДанныеНомераИзКеша(Строка.ИдентификаторНомера);
	
	Если ДанныеНомера = Неопределено И Не КешОбновлен Тогда
		ОбновитьКешНомеров();
		ДанныеНомера = ПолучитьДанныеНомераИзКеша(Строка.ИдентификаторНомера);
	КонецЕсли;	

	Если ДанныеНомера = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Строка.Номер = ДанныеНомера.Наименование;
	Строка.ОписаниеНомера = ДанныеНомера.Описание;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеНомераИзКеша(ИдентификаторНомера)
	
	БезопасныйИдентификатор = БезопасныйИдентификатор(ИдентификаторНомера);
	
	Если КешНомеров.Свойство(БезопасныйИдентификатор) Тогда
		Возврат КешНомеров[БезопасныйИдентификатор];
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Процедура ОбновитьКешНомеров()
	
	НастройкиПодключения = НастройкиПодключения();
	
	Соединение = УстановитьСоединение(НастройкиПодключения);
	
	АдресРесурса = НастройкиПодключения.ПутьНаСервере + "/hs/booking/rooms";
	
	Запрос = Новый HTTPЗапрос(АдресРесурса);
	Ответ = Соединение.Получить(Запрос);
	
	Если Ответ.КодСостояния <> 200 Тогда
		Сообщить("Ошибка подключения: " + Ответ.КодСостояния);
		Возврат;
	КонецЕсли;
	
	КешНомеров = Новый Структура;
	
	ТелоОтвета = Ответ.ПолучитьТелоКакСтроку();
	
	ДанныеОтвета = ПрочитатьЗначениеJSON(ТелоОтвета);
	
	Для Каждого ДанныеНомера Из ДанныеОтвета Цикл
		
		НомерОбъект = Новый Структура;
		НомерОбъект.Вставить("Идентификатор", ДанныеНомера.id);
		НомерОбъект.Вставить("Наименование", ДанныеНомера.name);
		НомерОбъект.Вставить("Код", ДанныеНомера.code);
		НомерОбъект.Вставить("Описание", ДанныеНомера.description);
		
		КешНомеров.Вставить(БезопасныйИдентификатор(ДанныеНомера.id), НомерОбъект);
		
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Функция БезопасныйИдентификатор(Идентификатор)
	
	Возврат "id_" + СтрЗаменить(Идентификатор, "-", "_");
	
КонецФункции

&НаКлиенте
Процедура Обновить(Команда)
	ОбновитьНаСервере();
КонецПроцедуры

&НаСервере
Функция ПроверитьПодключениеНаСервере()
	
	РезультатПроверки = Новый Структура;
	РезультатПроверки.Вставить("Успех", Истина);
	РезультатПроверки.Вставить("ТекстОшибки", "");
	
	НастройкиПодключения = НастройкиПодключения();
	
	Соединение = УстановитьСоединение(НастройкиПодключения);
	
	АдресРесурса = НастройкиПодключения.ПутьНаСервере + "/hs/booking/ping";
	
	Запрос = Новый HTTPЗапрос(АдресРесурса);
	Ответ = Соединение.Получить(Запрос);
	
	Если Ответ.КодСостояния = 200 Тогда
		Возврат РезультатПроверки;
	КонецЕсли;
	
	РезультатПроверки.Успех = Ложь;
	РезультатПроверки.ТекстОшибки = "Код состояния: " + Ответ.КодСостояния;
	
	Возврат РезультатПроверки;

КонецФункции

&НаКлиенте
Процедура ПроверитьПодключение(Команда)
	
	РезультатПроверки = ПроверитьПодключениеНаСервере();
	
	Если РезультатПроверки.Успех Тогда
		ПредупреждениеАсинх("Успех");
	Иначе
		ПредупреждениеАсинх(РезультатПроверки.ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

// Устанавливает соединение по HTTP с использованием заданных настроек.
//
// Параметры:
//   НастройкиПодключения - см. НастройкиПодключения()
//
// Возвращаемое значение:
//   HTTPСоединение - Объект установленного соединения или Неопределено в случае ошибки
Функция УстановитьСоединение(НастройкиПодключения)
	
	Возврат Новый HTTPСоединение(НастройкиПодключения.АдресСервера,, 
		НастройкиПодключения.Логин, 
		НастройкиПодключения.Пароль,, 
		120, 
		НастройкиПодключения.ЗащищенноеСоединение);
	
КонецФункции

// Формирует структуру настроек подключения к HTTP-ресурсу на основе адреса приложения и учетных данных.
//
// Возвращаемое значение:
//   Структура:
//     * АдресСервера - Строка - адрес сервера без протокола и пути
//     * ПутьНаСервере - Строка - путь на сервере (пустая строка, если не указан)
//     * ЗащищенноеСоединение - ЗащищенноеСоединениеOpenSSL, Неопределено - настройки защищенного соединения для HTTPS
//     * Логин - Строка - имя пользователя для аутентификации
//     * Пароль - Строка - пароль пользователя
Функция НастройкиПодключения()
		
	Результат = Новый Структура;
	
	Если СтрНачинаетсяС(АдресПриложения, "https") Тогда
		ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
	Иначе
		ЗащищенноеСоединение = Неопределено;
	КонецЕсли;
	
	Курсор = СтрНайти(АдресПриложения, "://");
	АдресБезПротокола = Сред(АдресПриложения, Курсор + 3); // localhost/narfu-151315-int
	
	Курсор = СтрНайти(АдресБезПротокола, "/");
	Если Курсор > 0 Тогда
		АдресСервера = Лев(АдресБезПротокола, Курсор - 1);
		ПутьНаСервере = Сред(АдресБезПротокола, Курсор);
	Иначе
		АдресСервера = АдресБезПротокола;
		ПутьНаСервере = "";
	КонецЕсли;
	
	Результат.Вставить("АдресСервера", АдресСервера);
	Результат.Вставить("ПутьНаСервере", ПутьНаСервере);
	Результат.Вставить("ЗащищенноеСоединение", ЗащищенноеСоединение);
	Результат.Вставить("Логин", Логин);
	Результат.Вставить("Пароль", Пароль);
	
	Возврат Результат;
	
КонецФункции
