&НаСервере
Процедура ЭкспериментБыстродействиеНаСервере()
	
	Дата = ТекущаяДатаСеанса();
	
	НачалоЗамераФормат = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Запись = Новый ЗаписьXML();
	Запись.УстановитьСтроку();
	
	Запись.ЗаписатьНачалоЭлемента("body");
	
	Для Сч = 1 По 100000 Цикл
		Запись.ЗаписатьНачалоЭлемента("startDate");
		Запись.ЗаписатьТекст(Формат(Дата, "ДФ=гггг-ММ-дд;"));
		Запись.ЗаписатьКонецЭлемента();		
	КонецЦикла;
	
	Запись.ЗаписатьКонецЭлемента();	// body
	
	Результат = Запись.Закрыть();
	
	Запись = Неопределено;
	Результат = Неопределено;
	
	Сообщить("Через формат: " + (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоЗамераФормат));
	
	НачалоЗамераXDTO = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Запись = Новый ЗаписьXML();
	Запись.УстановитьСтроку();
	
	Запись.ЗаписатьНачалоЭлемента("body");
	
	Для Сч = 1 По 100000 Цикл
		ТипЗначения = ФабрикаXDTO.Тип("http://www.w3.org/2001/XMLSchema", "date");
		ОбъектДата = ФабрикаXDTO.Создать(ТипЗначения, Дата);
		ФабрикаXDTO.ЗаписатьXML(Запись, ОбъектДата, "startDate", "http://narfu.ru/151315/booking");
	КонецЦикла;
	
	Запись.ЗаписатьКонецЭлемента();	// body
	
	Результат = Запись.Закрыть();
	
	Запись = Неопределено;
	Результат = Неопределено;
	
	Сообщить("Через XDTO: " + (ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоЗамераXDTO));

