&НаСервере
Процедура ВыгрузитьXDTOНаСервере()
	
	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку();
	Запись.ЗаписатьОбъявлениеXML();
	
	ТипЭкспортируемыеДанные = ФабрикаXDTO.Тип("http://narfu.ru/151315/booking", "exportData");
	ЭкспортируемыеДанныеXDTO = ФабрикаXDTO.Создать(ТипЭкспортируемыеДанные);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Номера.Ссылка)) КАК Идентификатор,
		|	Номера.Код КАК Код,
		|	Номера.Наименование КАК Наименование,
		|	Номера.Описание КАК Описание
		|ИЗ
		|	Справочник.Номера КАК Номера";
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	ТипСписокНомеров = ФабрикаXDTO.Тип("http://narfu.ru/151315/booking", "rooms");
	СписокНомеровXDTO = ФабрикаXDTO.Создать(ТипСписокНомеров);
	
	Пока Выборка.Следующий() Цикл
		
		ТипОписаниеНомера = ФабрикаXDTO.Тип("http://narfu.ru/151315/booking", "room");
		ОписаниеНомераXDTO = ФабрикаXDTO.Создать(ТипОписаниеНомера);
		
		ОписаниеНомераXDTO.id = Выборка.Идентификатор;
		ОписаниеНомераXDTO.code = Выборка.Код;
		ОписаниеНомераXDTO.name = Выборка.Наименование;
		ОписаниеНомераXDTO.description = Выборка.Описание;
		
		СписокНомеровXDTO.room.Добавить(ОписаниеНомераXDTO)
		
	КонецЦикла;
	
	ЭкспортируемыеДанныеXDTO.rooms = СписокНомеровXDTO;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ДатыБронирований.Номер)) КАК ИдентификаторНомера,
		|	ДатыБронирований.ДатаНачала КАК ДатаНачала,
		|	ДатыБронирований.ДатаОкончания КАК ДатаОкончания
		|ИЗ
		|	РегистрСведений.ДатыБронирований КАК ДатыБронирований";
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	ТипСписокБронирований = ФабрикаXDTO.Тип("http://narfu.ru/151315/booking", "books");
	СписокБронированийXDTO = ФабрикаXDTO.Создать(ТипСписокБронирований);
		
	Пока Выборка.Следующий() Цикл
		
		ТипОписаниеБронирования = ФабрикаXDTO.Тип("http://narfu.ru/151315/booking", "book");
		ОписаниеБронированияXDTO = ФабрикаXDTO.Создать(ТипОписаниеБронирования);
		
		ОписаниеБронированияXDTO.roomId = Выборка.ИдентификаторНомера;
		ОписаниеБронированияXDTO.startDate = Выборка.ДатаНачала;
		ОписаниеБронированияXDTO.endDate = Выборка.ДатаОкончания;
		
		СписокБронированийXDTO.book.Добавить(ОписаниеБронированияXDTO)
		
	КонецЦикла;
	
	ЭкспортируемыеДанныеXDTO.books = СписокБронированийXDTO;
	
	ФабрикаXDTO.ЗаписатьXML(Запись, ЭкспортируемыеДанныеXDTO);
	
	ДанныеXML = Запись.Закрыть();

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьXDTOНаСервере()
	
	Чтение = Новый ЧтениеXML();
	Чтение.УстановитьСтроку(ДанныеXML);
	
	ТипЭкспортируемыеДанные = ФабрикаXDTO.Тип("http://narfu.ru/151315/booking", "exportData");
	ЭкспортируемыеДанные = ФабрикаXDTO.ПрочитатьXML(Чтение, ТипЭкспортируемыеДанные);
	
	Чтение.Закрыть();
	
	Для Каждого ДанныеНомера Из ЭкспортируемыеДанные.rooms.room Цикл
		
		// Нормализация данных
		Идентификатор = ПолучитьИдентификаторИзСтроки(ДанныеНомера.id);
		
		Ссылка = Справочники.Номера.ПолучитьСсылку(Идентификатор);
		
		СпрОбъект = Ссылка.ПолучитьОбъект();
		Если СпрОбъект = Неопределено Тогда
			СпрОбъект = Справочники.Номера.СоздатьЭлемент();
			СпрОбъект.УстановитьСсылкуНового(Ссылка);
		КонецЕсли;
		СпрОбъект.Код = ДанныеНомера.code;
		СпрОбъект.Наименование = ДанныеНомера.name;
		СпрОбъект.Описание = ДанныеНомера.description;
		СпрОбъект.Записать();
		
	КонецЦикла;	

КонецПроцедуры

&НаСервере
Процедура ВыгрузитьXMLНаСервере()
	
	Запись = Новый ЗаписьXML;
	Запись.УстановитьСтроку();
	Запись.ЗаписатьОбъявлениеXML();
	
	// Начало записи тела выгрузки	
	Запись.ЗаписатьНачалоЭлемента("exportData");
	Запись.ЗаписатьСоответствиеПространстваИмен("", "http://narfu.ru/151315/booking");
	Запись.ЗаписатьСоответствиеПространстваИмен("xs", "http://www.w3.org/2001/XMLSchema");
	Запись.ЗаписатьСоответствиеПространстваИмен("xsi", "http://www.w3.org/2001/XMLSchema-instance");
	
	// Начало записи списка комнат
	Запись.ЗаписатьНачалоЭлемента("rooms");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Номера.Ссылка)) КАК Идентификатор,
		|	Номера.Код КАК Код,
		|	Номера.Наименование КАК Наименование,
		|	Номера.Описание КАК Описание
		|ИЗ
		|	Справочник.Номера КАК Номера";
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Запись.ЗаписатьНачалоЭлемента("room");
		Запись.ЗаписатьАтрибут("id", Выборка.Идентификатор);
		
		Запись.ЗаписатьНачалоЭлемента("name");
		Запись.ЗаписатьТекст(Выборка.Наименование);
		Запись.ЗаписатьКонецЭлемента();
		
		Запись.ЗаписатьНачалоЭлемента("code");
		Запись.ЗаписатьТекст(Выборка.Код);
		Запись.ЗаписатьКонецЭлемента();
		
		Запись.ЗаписатьНачалоЭлемента("description");
		Запись.ЗаписатьТекст(Выборка.Описание);
		Запись.ЗаписатьКонецЭлемента();
		
		Запись.ЗаписатьКонецЭлемента(); // room
		
	КонецЦикла;
	
	Запись.ЗаписатьКонецЭлемента(); // rooms
	//
	// Начало записи списка бронирований
	Запись.ЗаписатьНачалоЭлемента("books");	
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ДатыБронирований.Номер)) КАК ИдентификаторНомера,
		|	ДатыБронирований.ДатаНачала КАК ДатаНачала,
		|	ДатыБронирований.ДатаОкончания КАК ДатаОкончания
		|ИЗ
		|	РегистрСведений.ДатыБронирований КАК ДатыБронирований";
		
	Выборка = Запрос.Выполнить().Выбрать();
		
	Пока Выборка.Следующий() Цикл
		
		Запись.ЗаписатьНачалоЭлемента("book");	
		
		Запись.ЗаписатьНачалоЭлемента("roomId");
		Запись.ЗаписатьТекст(Выборка.ИдентификаторНомера);
		Запись.ЗаписатьКонецЭлемента();		

		ТипЗначения = ФабрикаXDTO.Тип("http://www.w3.org/2001/XMLSchema", "date");
		ОбъектДата = ФабрикаXDTO.Создать(ТипЗначения, Выборка.ДатаНачала);
		ФабрикаXDTO.ЗаписатьXML(Запись, ОбъектДата, "startDate", "http://narfu.ru/151315/booking");
		
		ТипЗначения = ФабрикаXDTO.Тип("http://www.w3.org/2001/XMLSchema", "date");
		ОбъектДата = ФабрикаXDTO.Создать(ТипЗначения, Выборка.ДатаОкончания);
		ФабрикаXDTO.ЗаписатьXML(Запись, ОбъектДата, "endDate", "http://narfu.ru/151315/booking");
		
		Запись.ЗаписатьКонецЭлемента(); // book
	
	КонецЦикла;
	
	Запись.ЗаписатьКонецЭлемента(); // books
	
	// Завершение записи тела выгрузки
	Запись.ЗаписатьКонецЭлемента();
	
	ДанныеXML = Запись.Закрыть();

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьXMLНаСервере()

	Чтение = Новый ЧтениеXML;
	Чтение.УстановитьСтроку(ДанныеXML);
		
	Если Не Чтение.Прочитать() Тогда
		ВызватьИсключение "Неожиданный конец XML файла";
	КонецЕсли;
	
	Если Не (Чтение.ТипУзла = ТипУзлаXML.НачалоЭлемента
		И Чтение.Имя = "exportData") Тогда
		ВызватьИсключение "Ожидается начало элемента exportData";
	КонецЕсли;
	
	Если Не Чтение.Прочитать() Тогда
		ВызватьИсключение "Неожиданный конец XML файла";
	КонецЕсли;
	
	Если Не (Чтение.ТипУзла = ТипУзлаXML.НачалоЭлемента
		И Чтение.Имя = "rooms") Тогда
		ВызватьИсключение "Ожидается начало элемента rooms";
	КонецЕсли;
	
	ЗагрузитьСписокКомнат(Чтение);
	
	ЗагрузитьСписокБронирований(Чтение);
	
	Чтение.Закрыть();

КонецПроцедуры

&НаСервере
Процедура ВыгрузитьDOMНаСервере()
	
	Документ = Новый ДокументDOM("http://narfu.ru/151315/booking", "exportData");
	
	СписокКомнат = Документ.СоздатьЭлемент("rooms");
	Документ.ЭлементДокумента.ДобавитьДочерний(СписокКомнат);
	
	Документ.ЭлементДокумента.УстановитьСоответствиеПространстваИмен("xs", "http://www.w3.org/2001/XMLSchema");
	Документ.ЭлементДокумента.УстановитьСоответствиеПространстваИмен("xsi", "http://www.w3.org/2001/XMLSchema-instance");	
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Номера.Ссылка)) КАК Идентификатор,
		|	Номера.Код КАК Код,
		|	Номера.Наименование КАК Наименование,
		|	Номера.Описание КАК Описание
		|ИЗ
		|	Справочник.Номера КАК Номера";
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Комната = Документ.СоздатьЭлемент("room");
		Комната.УстановитьАтрибут("id", Выборка.Идентификатор);
		
		ЭлементНаименование = Документ.СоздатьЭлемент("name");
		ЭлементНаименование.ТекстовоеСодержимое = Выборка.Наименование;
		Комната.ДобавитьДочерний(ЭлементНаименование);
		
		ЭлементКод = Документ.СоздатьЭлемент("code");
		ЭлементКод.ТекстовоеСодержимое = Выборка.Код;
		Комната.ДобавитьДочерний(ЭлементКод);
		
		ЭлементОписание = Документ.СоздатьЭлемент("description");
		ЭлементОписание.ТекстовоеСодержимое = Выборка.Описание;
		Комната.ДобавитьДочерний(ЭлементОписание);
		
		СписокКомнат.ДобавитьДочерний(Комната);
		
	КонецЦикла;

	СписокБронирований = Документ.СоздатьЭлемент("books");
	Документ.ЭлементДокумента.ДобавитьДочерний(СписокБронирований);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ДатыБронирований.Номер)) КАК ИдентификаторНомера,
		|	ДатыБронирований.ДатаНачала КАК ДатаНачала,
		|	ДатыБронирований.ДатаОкончания КАК ДатаОкончания
		|ИЗ
		|	РегистрСведений.ДатыБронирований КАК ДатыБронирований";
		
	Выборка = Запрос.Выполнить().Выбрать();
		
	Пока Выборка.Следующий() Цикл
		
		Бронирование = Документ.СоздатьЭлемент("book");
		
		ЭлементИдентификаторКомнаты = Документ.СоздатьЭлемент("roomId");
		ЭлементИдентификаторКомнаты.ТекстовоеСодержимое = Выборка.ИдентификаторНомера;
		Бронирование.ДобавитьДочерний(ЭлементИдентификаторКомнаты);
		
		ЭлементИдентификаторКомнаты = Документ.СоздатьЭлемент("startDate");
		ЭлементИдентификаторКомнаты.ТекстовоеСодержимое = ДатаДляXML(Выборка.ДатаНачала);
		Бронирование.ДобавитьДочерний(ЭлементИдентификаторКомнаты);
		
		ЭлементИдентификаторКомнаты = Документ.СоздатьЭлемент("endDate");
		ЭлементИдентификаторКомнаты.ТекстовоеСодержимое = ДатаДляXML(Выборка.ДатаОкончания);
		Бронирование.ДобавитьДочерний(ЭлементИдентификаторКомнаты);
		
		СписокБронирований.ДобавитьДочерний(Бронирование);
	
	КонецЦикла;	
	
	ЗаписьDOM = Новый ЗаписьDOM();
	Запись = Новый ЗаписьXML();
	Запись.УстановитьСтроку();
	ЗаписьDOM.Записать(Документ, Запись);
	ДанныеXML = Запись.Закрыть();
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьDOMНаСервере()
	
	Чтение = Новый ЧтениеXML;
	Чтение.УстановитьСтроку(ДанныеXML);
	
	Построитель = Новый ПостроительDOM();
	Дерево = Построитель.Прочитать(Чтение);
	
	Для Каждого Список Из Дерево.ЭлементДокумента.ДочерниеУзлы Цикл
		Если Список.ИмяУзла = "rooms" Тогда
			ЗагрузитьКомнаты(Список);
		КонецЕсли;
		Если Список.ИмяУзла = "books" Тогда
			ЗагрузитьБронирования(Список);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьКомнаты(Список)
	
	Для Каждого Комната Из Список.ДочерниеУзлы Цикл
		
		ИдентификаторСтрока = Комната.Атрибуты.ПолучитьИменованныйЭлемент("id").Значение;
		Код = "";
		Наименование = "";
		Описание = "";
		
		Для Каждого РеквизитКомнаты Из Комната.ДочерниеУзлы Цикл
			Если РеквизитКомнаты.ИмяУзла = "code" Тогда
				Код = РеквизитКомнаты.ТекстовоеСодержимое;
			КонецЕсли;
			Если РеквизитКомнаты.ИмяУзла = "name" Тогда
				Наименование = РеквизитКомнаты.ТекстовоеСодержимое;
			КонецЕсли;
			Если РеквизитКомнаты.ИмяУзла = "description" Тогда
				Описание = РеквизитКомнаты.ТекстовоеСодержимое;
			КонецЕсли;
		КонецЦикла;
		
		// Нормализация данных
		Идентификатор = ПолучитьИдентификаторИзСтроки(ИдентификаторСтрока);
		
		Ссылка = Справочники.Номера.ПолучитьСсылку(Идентификатор);
		
		СпрОбъект = Ссылка.ПолучитьОбъект();
		Если СпрОбъект = Неопределено Тогда
			СпрОбъект = Справочники.Номера.СоздатьЭлемент();
			СпрОбъект.УстановитьСсылкуНового(Ссылка);
		КонецЕсли;
		СпрОбъект.Код = Код;
		СпрОбъект.Наименование = Наименование;
		СпрОбъект.Описание = Описание;
		СпрОбъект.Записать();	
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьБронирования(Список)
	
	НаборЗаписей = РегистрыСведений.ДатыБронирований.СоздатьНаборЗаписей();
	
	Для Каждого Бронирование Из Список.ДочерниеУзлы Цикл
		
		ИдентификаторКомнаты = "";
		ДатаНачала = "";		
		ДатаОкончания = "";
		
		Для Каждого РеквизитКомнаты Из Бронирование.ДочерниеУзлы Цикл
			Если РеквизитКомнаты.ИмяУзла = "roomId" Тогда
				ИдентификаторКомнаты = РеквизитКомнаты.ТекстовоеСодержимое;
			КонецЕсли;
			Если РеквизитКомнаты.ИмяУзла = "startDate" Тогда
				ДатаНачала = РеквизитКомнаты.ТекстовоеСодержимое;
			КонецЕсли;
			Если РеквизитКомнаты.ИмяУзла = "endDate" Тогда
				ДатаОкончания = РеквизитКомнаты.ТекстовоеСодержимое;
			КонецЕсли;
		КонецЦикла;
	
		// Нормализация данных
		Идентификатор = ПолучитьИдентификаторИзСтроки(ИдентификаторКомнаты);
		
		Ссылка = Справочники.Номера.ПолучитьСсылку(Идентификатор);
		
		Запись = НаборЗаписей.Добавить();
		
		Запись.Номер = Ссылка;
		Запись.ДатаНачала = XMLЗначение(Тип("Дата"), ДатаНачала);
		Запись.ДатаОкончания = XMLЗначение(Тип("Дата"), ДатаОкончания);
		
	КонецЦикла;
	
	НаборЗаписей.Записать(РежимЗамещения.Слияние);	
	
КонецПроцедуры

