// Читает данные из узла XML и создает или обновляет элементы справочника Номера.
//
// Параметры:
//   ЧтениеXML - ЧтениеXML - Объект чтения XML, установленный на узел с атрибутом id
&НаСервере
Процедура ЗагрузитьСписокКомнат(ЧтениеXML)
	
	Если Не (ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
		И ЧтениеXML.Имя = "rooms") Тогда
		ВызватьИсключение "Ожидается начало элемента rooms";
	КонецЕсли;
	
	Если Не ЧтениеXML.Прочитать() Тогда
		ВызватьИсключение "Неожиданный конец XML файла";
	КонецЕсли;
	
	Пока ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
		И ЧтениеXML.Имя = "room"  Цикл
		
		ПрочитатьНомерИзXML(ЧтениеXML);
		
	КонецЦикла;
	
	Если ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента Тогда
		Если Не ЧтениеXML.Прочитать() Тогда
			ВызватьИсключение "Неожиданный конец XML файла";
		КонецЕсли;
	Иначе
		ВызватьИсключение "Ожидается конец элемента rooms";		
	КонецЕсли;	
	
КонецПроцедуры

// Читает данные из узла XML и создает или обновляет элемент справочника Номера.
//
// Параметры:
//   ЧтениеXML - ЧтениеXML - Объект чтения XML, установленный на узел с атрибутом id
&НаСервере
Процедура ПрочитатьНомерИзXML(ЧтениеXML)
	
	ТипТипКомната = ФабрикаXDTO.Тип("http://narfu.ru/151315/booking", "room");
	ДанныеНомера = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML, ТипТипКомната);
	
	// Нормализация данных
	Идентификатор = ПолучитьИдентификаторИзСтроки(ДанныеНомера.id);
	
	Ссылка = Справочники.Номера.ПолучитьСсылку(Идентификатор);
	
	СпрОбъект = Ссылка.ПолучитьОбъект();
	Если СпрОбъект = Неопределено Тогда
		СпрОбъект = Справочники.Номера.СоздатьЭлемент();
		СпрОбъект.УстановитьСсылкуНового(Ссылка);
	КонецЕсли;
	СпрОбъект.Код = ДанныеНомера.code;
	СпрОбъект.Наименование = ДанныеНомера.name;
	СпрОбъект.Описание = ДанныеНомера.description;
	СпрОбъект.Записать();
	
	Возврат;
	
	Если ЧтениеXML.ТипУзла <> ТипУзлаXML.НачалоЭлемента Тогда
		ВызватьИсключение "Ожидается начало элемента room";
	КонецЕсли;
	
	Если ЧтениеXML.Имя <> "room" Тогда
		ВызватьИсключение "Ожидается начало элемента room";
	КонецЕсли;
		
	ИдентификаторСтрока = ЧтениеXML.ПолучитьАтрибут("id");
	Наименование = "";
	Код = "";
	Описание = "";
	
	// Читаем наименование
	ЧтениеXML.Прочитать();
	ЧтениеXML.Прочитать();
	Если ЧтениеXML.ТипУзла = ТипУзлаXML.Текст Тогда
		Наименование = ЧтениеXML.Значение;
		ЧтениеXML.Прочитать();
	КонецЕсли;
	
	// Читаем код
	ЧтениеXML.Прочитать();
	ЧтениеXML.Прочитать();
	Если ЧтениеXML.ТипУзла = ТипУзлаXML.Текст Тогда
		Код = ЧтениеXML.Значение;
		ЧтениеXML.Прочитать();
	КонецЕсли;
	
	// Читаем описание
	ЧтениеXML.Прочитать();
	ЧтениеXML.Прочитать();
	Если ЧтениеXML.ТипУзла = ТипУзлаXML.Текст Тогда
		Описание = ЧтениеXML.Значение;
		ЧтениеXML.Прочитать();
	КонецЕсли;
	
	// Нормализация данных
	Идентификатор = ПолучитьИдентификаторИзСтроки(ИдентификаторСтрока);
	
	Ссылка = Справочники.Номера.ПолучитьСсылку(Идентификатор);
	
	СпрОбъект = Ссылка.ПолучитьОбъект();
	Если СпрОбъект = Неопределено Тогда
		СпрОбъект = Справочники.Номера.СоздатьЭлемент();
		СпрОбъект.УстановитьСсылкуНового(Ссылка);
	КонецЕсли;
	СпрОбъект.Код = Код;
	СпрОбъект.Наименование = Наименование;
	СпрОбъект.Описание = Описание;
	СпрОбъект.Записать();
	
	ЧтениеXML.Прочитать();
	ЧтениеXML.Прочитать();	
	
КонецПроцедуры

// Читает данные из узла XML и создает или обновляет набор записей бронирования.
//
// Параметры:
//   ЧтениеXML - ЧтениеXML - Объект чтения XML, установленный на узел с атрибутом books
&НаСервере
Процедура ЗагрузитьСписокБронирований(ЧтениеXML)
	
	Если Не (ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
		И ЧтениеXML.Имя = "books") Тогда
		ВызватьИсключение "Ожидается начало элемента books";
	КонецЕсли;
	
	Если Не ЧтениеXML.Прочитать() Тогда
		ВызватьИсключение "Неожиданный конец XML файла";
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.ДатыБронирований.СоздатьНаборЗаписей();
	
	Пока ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента
		И ЧтениеXML.Имя = "book"  Цикл
		
		ПрочитатьБронированиеИзXML(ЧтениеXML, НаборЗаписей);
		
	КонецЦикла;
	
	НаборЗаписей.Записать(РежимЗамещения.Слияние);
	
	Если ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента Тогда
		Если Не ЧтениеXML.Прочитать() Тогда
			ВызватьИсключение "Неожиданный конец XML файла";
		КонецЕсли;
	Иначе
		ВызватьИсключение "Ожидается конец элемента books";		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьБронированиеИзXML(ЧтениеXML, НаборЗаписей)
	
	Если ЧтениеXML.ТипУзла <> ТипУзлаXML.НачалоЭлемента Тогда
		ВызватьИсключение "Ожидается начало элемента book";
	КонецЕсли;
	
	Если ЧтениеXML.Имя <> "book" Тогда
		ВызватьИсключение "Ожидается начало элемента book";
	КонецЕсли;
	
	ИдентификаторКомнаты = "";
	ДатаНачала = "";
	ДатаОкончания = "";
	
	// Читаем идентификатор комнаты
	ЧтениеXML.Прочитать();
	ЧтениеXML.Прочитать();
	Если ЧтениеXML.ТипУзла = ТипУзлаXML.Текст Тогда
		ИдентификаторКомнаты = ЧтениеXML.Значение;
		ЧтениеXML.Прочитать();
	КонецЕсли;
	
	// Читаем дату начала
	ЧтениеXML.Прочитать();
	ЧтениеXML.Прочитать();
	Если ЧтениеXML.ТипУзла = ТипУзлаXML.Текст Тогда
		ДатаНачала = ЧтениеXML.Значение;
		ЧтениеXML.Прочитать();
	КонецЕсли;
	
	// Читаем дату окончания
	ЧтениеXML.Прочитать();
	ЧтениеXML.Прочитать();
	Если ЧтениеXML.ТипУзла = ТипУзлаXML.Текст Тогда
		ДатаОкончания = ЧтениеXML.Значение;
		ЧтениеXML.Прочитать();
	КонецЕсли;
	
	// Нормализация данных
	Идентификатор = ПолучитьИдентификаторИзСтроки(ИдентификаторКомнаты);
	
	Ссылка = Справочники.Номера.ПолучитьСсылку(Идентификатор);
	
	Запись = НаборЗаписей.Добавить();
	
	Запись.Номер = Ссылка;
	Запись.ДатаНачала = XMLЗначение(Тип("Дата"), ДатаНачала);
	Запись.ДатаОкончания = XMLЗначение(Тип("Дата"), ДатаОкончания);
	
	ЧтениеXML.Прочитать();
	ЧтениеXML.Прочитать();
	
КонецПроцедуры


&НаСервере
Функция ПолучитьИдентификаторИзСтроки(ИдентификаторСтрока)
	
	// Стандартный шаблон uuid
	Шаблон = "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}";
	
	Если СтрПодобнаПоРегулярномуВыражению(ИдентификаторСтрока, Шаблон, Истина) Тогда
		Возврат Новый УникальныйИдентификатор(ИдентификаторСтрока);
	КонецЕсли;
	
	ВызватьИсключение "Некорректный идентификатор";
	
КонецФункции

